# Karigar Server — Environment Variables
# Copy this file to .env and fill in your worker URLs.
# Run the matching setup script in server/scripts/ to get each URL.

# Google Colab worker (T4 GPU, 12hr sessions — run setup-colab.py each morning)
COLAB_BASEURL=https://your-ngrok-url.ngrok.io

# Kaggle worker (T4/P100 GPU, 30hr/week — run setup-kaggle.py to get URL)
KAGGLE_BASEURL=https://your-ngrok-url.ngrok.io

# Oracle ARM worker (always-on free tier — set once, never changes)
ORACLE_BASEURL=http://your-oracle-public-ip:11434

# Lightning CPU worker (always-on fallback)
LIGHTNING_CPU_BASEURL=http://your-lightning-url:11434

# Auth token — optional but recommended if exposing server to the internet
# Set the same token in karigar connect -t <token>
AUTH_TOKEN=

# Server port (default: 3000)
PORT=3000
